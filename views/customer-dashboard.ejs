<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Quick 2 Pay - Customer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
    <style>
        .camera-view { width: 100%; max-width: 500px; margin: 0 auto; }
        #reader, #itemScanner { width: 100%; }
        .success-toast {
            position: fixed;
            bottom: 30%;
            left: 50%;
            transform: translateX(-50%);
            z-index: 50;
            transition: opacity 0.3s;
        }
    </style>
</head>
<body class="bg-black text-white">
    <div class="container mx-auto p-4 max-w-md">
        <div class="flex justify-between items-center mb-4">
            <h1 class="text-2xl font-bold text-yellow-400">Quick 2 Pay</h1>
            <a href="/customer/logout" class="text-sm bg-gray-800 px-3 py-1 rounded">Logout</a>
        </div>

        <!-- Two scan options -->
        <div class="grid grid-cols-2 gap-2 mb-4">
            <button id="scanStoreQrBtn" class="bg-yellow-500 text-black py-2 rounded font-bold">Scan Store QR</button>
            <button id="scanProductQrBtn" class="bg-gray-700 py-2 rounded font-bold">Scan Product QR</button>
        </div>

        <!-- Manual product token entry (for custom products) -->
        <div class="bg-gray-800 p-2 rounded mb-4 flex gap-2">
            <input type="text" id="manualProductToken" placeholder="Or paste product token" class="flex-1 bg-gray-700 p-2 rounded text-sm">
            <button id="manualProductTokenBtn" class="bg-yellow-600 px-3 py-1 rounded text-sm">Add by Token</button>
        </div>

        <!-- Step 1: Merchant QR (store) -->
        <div id="stepMerchant" class="bg-gray-900 rounded-lg p-4 mb-4 hidden">
            <div id="merchantReaderContainer"></div>
            <div class="mt-3 text-center">
                <p class="text-xs text-gray-500">Or enter merchant code manually:</p>
                <input type="text" id="manualMerchantCode" placeholder="Paste merchant QR code" class="w-full p-2 rounded bg-gray-800 text-sm mt-1">
                <button id="manualVerifyBtn" class="bg-gray-700 text-white px-3 py-1 rounded text-sm mt-1">Verify</button>
            </div>
            <div id="merchantInfo" class="mt-2 text-center text-sm text-gray-400"></div>
        </div>

        <!-- Step 1B: Product QR (direct checkout) -->
        <div id="stepProductQr" class="bg-gray-900 rounded-lg p-4 mb-4 hidden">
            <div id="productReaderContainer"></div>
            <div id="productQrInfo" class="mt-2 text-center text-sm"></div>
        </div>

        <!-- Step 2: Add Items (only for store flow) -->
        <div id="stepItems" class="hidden">
            <div class="bg-gray-900 rounded-lg p-4 mb-4">
                <div class="flex justify-between items-center mb-2">
                    <span class="font-semibold">Store: <span id="storeName"></span></span>
                    <button id="addItemsBtn" class="bg-yellow-600 px-3 py-1 rounded text-sm">📷 Start Barcode Scanner</button>
                </div>
                <div id="itemScannerContainer" class="hidden mt-2"></div>
                <div class="mt-2">
                    <input type="text" id="manualBarcode" placeholder="Or type barcode number manually" class="w-full p-2 rounded bg-gray-800 text-sm">
                    <button id="manualAddBtn" class="bg-gray-700 text-white px-3 py-1 rounded text-sm mt-1">Add Item</button>
                </div>
                <div class="mt-4 border-t border-gray-700 pt-2">
                    <div class="flex gap-2 mb-2">
                        <input type="text" id="searchProductInput" placeholder="Search products by name or barcode" class="flex-1 bg-gray-800 p-2 rounded text-sm">
                        <button id="searchProductBtn" class="bg-gray-700 px-3 py-1 rounded text-sm">Search</button>
                    </div>
                    <div id="productCatalog" class="max-h-40 overflow-y-auto space-y-2 text-sm"></div>
                </div>
                <div id="cartPreview" class="mt-4">
                    <h3 class="font-bold">Cart</h3>
                    <div id="cartItemsList" class="text-sm space-y-1 max-h-40 overflow-y-auto"></div>
                    <div class="border-t border-gray-700 mt-2 pt-2 flex justify-between font-bold">
                        <span>Subtotal:</span>
                        <span id="cartSubtotal">R0.00</span>
                    </div>
                    <button id="viewCartBtn" class="mt-3 bg-yellow-600 w-full py-2 rounded">See Cart & Checkout</button>
                </div>
            </div>
        </div>

        <!-- Recent Transactions (clickable) -->
        <div class="mt-6">
            <h2 class="font-semibold mb-2">Recent Payments</h2>
            <div id="recentTxns" class="space-y-2 text-sm"></div>
        </div>
    </div>

    <!-- Success Toast -->
    <div id="successToast" class="success-toast hidden bg-green-800 rounded-lg p-4 shadow-lg text-center min-w-[250px]">
        <div class="flex items-center justify-center gap-2 mb-2">
            <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <span class="font-bold">Item added!</span>
        </div>
        <div id="toastItemName" class="text-sm mb-3"></div>
        <div class="flex gap-2">
            <button id="continueScanBtn" class="flex-1 bg-yellow-500 text-black py-1 rounded text-sm">Continue Scanning</button>
            <button id="gotoCartBtn" class="flex-1 bg-gray-700 py-1 rounded text-sm">View Cart</button>
        </div>
    </div>

    <script>
        let currentMerchantId = null, currentStoreName = '', cart = [], subtotal = 0;
        const stepMerchantDiv = document.getElementById('stepMerchant');
        const stepProductQrDiv = document.getElementById('stepProductQr');
        const stepItemsDiv = document.getElementById('stepItems');
        const storeNameSpan = document.getElementById('storeName');
        const cartItemsList = document.getElementById('cartItemsList');
        const cartSubtotalSpan = document.getElementById('cartSubtotal');
        const addItemsBtn = document.getElementById('addItemsBtn');
        const itemScannerContainer = document.getElementById('itemScannerContainer');
        let itemScannerInstance = null;

        const toast = document.getElementById('successToast');
        const toastItemName = document.getElementById('toastItemName');
        const continueScanBtn = document.getElementById('continueScanBtn');
        const gotoCartBtn = document.getElementById('gotoCartBtn');

        function showSuccessToast(itemName, onContinue, onViewCart) {
            toastItemName.innerText = `${itemName} added to cart`;
            toast.classList.remove('hidden');
            const newContinue = () => { toast.classList.add('hidden'); onContinue(); };
            const newViewCart = () => { toast.classList.add('hidden'); onViewCart(); };
            continueScanBtn.replaceWith(continueScanBtn.cloneNode(true));
            gotoCartBtn.replaceWith(gotoCartBtn.cloneNode(true));
            const newContinueBtn = document.getElementById('continueScanBtn');
            const newGotoCartBtn = document.getElementById('gotoCartBtn');
            newContinueBtn.addEventListener('click', newContinue);
            newGotoCartBtn.addEventListener('click', newViewCart);
        }

        function updateCartPreview() {
            if (cart.length === 0) { cartItemsList.innerHTML = '<div class="text-gray-500">No items</div>'; cartSubtotalSpan.innerText = 'R0.00'; return; }
            cartItemsList.innerHTML = cart.map(item => `
                <div class="flex justify-between items-center">
                    <div class="flex items-center gap-2">
                        ${item.image_url ? `<img src="${item.image_url}" class="w-8 h-8 object-cover rounded">` : '<div class="w-8 h-8 bg-gray-700 rounded"></div>'}
                        <div>${item.name} x${item.quantity}</div>
                    </div>
                    <div>R${(item.price * item.quantity / 100).toFixed(2)}</div>
                </div>
            `).join('');
            subtotal = cart.reduce((sum, i) => sum + (i.price * i.quantity), 0);
            cartSubtotalSpan.innerText = `R${(subtotal / 100).toFixed(2)}`;
            sessionStorage.setItem('checkoutCart', JSON.stringify(cart));
            sessionStorage.setItem('checkoutMerchantId', currentMerchantId);
        }

        function addItemToCart(item, callbackAfterAdd) {
            const existing = cart.find(i => i.barcode === item.barcode);
            if (existing) existing.quantity++;
            else cart.push({ barcode: item.barcode, name: item.name, price: item.price, quantity: 1, image_url: item.image_url });
            updateCartPreview();
            if (callbackAfterAdd) callbackAfterAdd();
        }

        function addItemByBarcode(barcode, onSuccessCallback) {
            fetch('/customer/api/add-item', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ merchantId: currentMerchantId, barcode }) })
            .then(res => res.json()).then(item => {
                if (item.success) {
                    addItemToCart(item, () => { if (onSuccessCallback) onSuccessCallback(item.name); });
                } else {
                    alert(item.message);
                    if (onSuccessCallback) onSuccessCallback(null);
                }
            }).catch(err => alert('Error adding item'));
        }

        function loadProductCatalog(query = '') {
            let url = `/customer/api/merchant-products?merchantId=${currentMerchantId}`;
            if (query) url += `&search=${encodeURIComponent(query)}`;
            fetch(url).then(res => res.json()).then(products => {
                const catalogDiv = document.getElementById('productCatalog');
                if (!products || products.length === 0) {
                    catalogDiv.innerHTML = '<div class="text-gray-500">No products available in this store</div>';
                    return;
                }
                catalogDiv.innerHTML = products.map(p => `
                    <div class="bg-gray-800 p-2 rounded flex justify-between items-center cursor-pointer hover:bg-gray-700 product-item" data-barcode="${p.barcode}" data-name="${p.name}" data-price="${p.price}" data-image="${p.image_url || ''}">
                        <div class="flex items-center gap-2">
                            ${p.image_url ? `<img src="${p.image_url}" class="w-8 h-8 object-cover rounded">` : '<div class="w-8 h-8 bg-gray-700 rounded"></div>'}
                            <div><span class="font-semibold">${p.name}</span><br><span class="text-yellow-400 text-xs">R${(p.price/100).toFixed(2)}</span></div>
                        </div>
                        <button class="add-from-catalog bg-yellow-600 px-2 py-1 rounded text-xs" data-barcode="${p.barcode}" data-name="${p.name}" data-price="${p.price}" data-image="${p.image_url || ''}">Add</button>
                    </div>
                `).join('');
                document.querySelectorAll('.add-from-catalog').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        e.stopPropagation();
                        addItemByCatalog(btn.dataset.barcode, btn.dataset.name, parseInt(btn.dataset.price), btn.dataset.image);
                    });
                });
                document.querySelectorAll('.product-item').forEach(row => {
                    row.addEventListener('click', (e) => {
                        if (e.target.classList.contains('add-from-catalog')) return;
                        addItemByCatalog(row.dataset.barcode, row.dataset.name, parseInt(row.dataset.price), row.dataset.image);
                    });
                });
            }).catch(err => console.error(err));
        }

        function addItemByCatalog(barcode, name, price, image_url) {
            addItemToCart({ barcode, name, price, image_url }, () => {
                showSuccessToast(name, () => {}, () => { window.location.href = '/customer/cart'; });
            });
        }

        // Store QR scanning
        document.getElementById('scanStoreQrBtn').addEventListener('click', () => {
            stepProductQrDiv.classList.add('hidden');
            stepMerchantDiv.classList.remove('hidden');
            const readerDiv = document.createElement('div'); readerDiv.id = 'merchantReader'; readerDiv.style.width = '100%'; readerDiv.style.height = '300px';
            document.getElementById('merchantReaderContainer').innerHTML = '';
            document.getElementById('merchantReaderContainer').appendChild(readerDiv);
            const html5QrCode = new Html5Qrcode("merchantReader");
            html5QrCode.start({ facingMode: "environment" }, { fps: 10, qrbox: { width: 250, height: 250 } }, (decodedText) => {
                fetch('/customer/api/verify-merchant', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ qrData: decodedText }) })
                .then(res => res.json()).then(data => {
                    if (data.success) {
                        currentMerchantId = data.merchantId;
                        currentStoreName = data.storeName;
                        storeNameSpan.innerText = currentStoreName;
                        html5QrCode.stop();
                        stepMerchantDiv.classList.add('hidden');
                        stepItemsDiv.classList.remove('hidden');
                        cart = [];
                        updateCartPreview();
                        document.getElementById('merchantInfo').innerHTML = `<span class="text-green-400">✓ Verified: ${currentStoreName}</span>`;
                        loadProductCatalog();
                    } else alert('Invalid merchant QR');
                });
            }).catch(console.error);
        });

        document.getElementById('manualVerifyBtn').addEventListener('click', () => {
            const qrData = document.getElementById('manualMerchantCode').value.trim();
            if (!qrData) return alert('Enter a merchant code');
            fetch('/customer/api/verify-merchant', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ qrData }) })
            .then(res => res.json()).then(data => {
                if (data.success) {
                    currentMerchantId = data.merchantId;
                    currentStoreName = data.storeName;
                    storeNameSpan.innerText = currentStoreName;
                    stepMerchantDiv.classList.add('hidden');
                    stepItemsDiv.classList.remove('hidden');
                    cart = [];
                    updateCartPreview();
                    document.getElementById('merchantInfo').innerHTML = `<span class="text-green-400">✓ Verified: ${currentStoreName}</span>`;
                    loadProductCatalog();
                } else alert('Invalid merchant QR');
            });
        });

        // Product QR scanning (direct checkout)
        document.getElementById('scanProductQrBtn').addEventListener('click', () => {
            stepMerchantDiv.classList.add('hidden');
            stepItemsDiv.classList.add('hidden');
            stepProductQrDiv.classList.remove('hidden');
            const readerDiv = document.createElement('div'); readerDiv.id = 'productReader'; readerDiv.style.width = '100%'; readerDiv.style.height = '300px';
            document.getElementById('productReaderContainer').innerHTML = '';
            document.getElementById('productReaderContainer').appendChild(readerDiv);
            const html5QrCode = new Html5Qrcode("productReader");
            html5QrCode.start({ facingMode: "environment" }, { fps: 10, qrbox: { width: 250, height: 250 } }, (decodedText) => {
                fetch('/customer/api/verify-custom-product', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ token: decodedText }) })
                .then(res => res.json()).then(data => {
                    if (data.success) {
                        html5QrCode.stop();
                        currentMerchantId = data.merchantId;
                        currentStoreName = data.storeName;
                        const product = data.product;
                        cart = [{
                            barcode: `custom_${product.id}`,
                            name: product.name,
                            price: product.price,
                            quantity: 1,
                            image_url: product.image_url || ''
                        }];
                        updateCartPreview();
                        sessionStorage.setItem('checkoutCart', JSON.stringify(cart));
                        sessionStorage.setItem('checkoutMerchantId', currentMerchantId);
                        window.location.href = '/customer/cart';
                    } else {
                        alert(data.message || 'Invalid product QR');
                        stepProductQrDiv.classList.add('hidden');
                    }
                });
            }).catch(console.error);
        });

        // Manual product token entry
        document.getElementById('manualProductTokenBtn').addEventListener('click', () => {
            const token = document.getElementById('manualProductToken').value.trim();
            if (!token) return alert('Enter a product token');
            fetch('/customer/api/verify-custom-product', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ token }) })
            .then(res => res.json()).then(data => {
                if (data.success) {
                    currentMerchantId = data.merchantId;
                    currentStoreName = data.storeName;
                    const product = data.product;
                    cart = [{
                        barcode: `custom_${product.id}`,
                        name: product.name,
                        price: product.price,
                        quantity: 1,
                        image_url: product.image_url || ''
                    }];
                    updateCartPreview();
                    sessionStorage.setItem('checkoutCart', JSON.stringify(cart));
                    sessionStorage.setItem('checkoutMerchantId', currentMerchantId);
                    window.location.href = '/customer/cart';
                } else {
                    alert(data.message || 'Invalid product token');
                }
            });
        });

        // Item scanning (camera) for barcodes
        function startItemScanning() {
            if (itemScannerInstance) return;
            itemScannerContainer.classList.remove('hidden');
            itemScannerContainer.innerHTML = '<div id="itemReader" style="width:100%; height:250px;"></div>';
            itemScannerInstance = new Html5Qrcode("itemReader");
            itemScannerInstance.start({ facingMode: "environment" }, { fps: 10, qrbox: { width: 250, height: 250 } }, (barcode) => {
                itemScannerInstance.pause();
                addItemByBarcode(barcode, (itemName) => {
                    if (itemName) {
                        showSuccessToast(itemName, () => { itemScannerInstance.resume(); }, () => {
                            sessionStorage.setItem('checkoutCart', JSON.stringify(cart));
                            sessionStorage.setItem('checkoutMerchantId', currentMerchantId);
                            window.location.href = '/customer/cart';
                        });
                    } else {
                        itemScannerInstance.resume();
                    }
                });
            }).catch(console.error);
        }
        function stopItemScanning() {
            if (itemScannerInstance) {
                itemScannerInstance.stop().then(() => { itemScannerInstance = null; itemScannerContainer.classList.add('hidden'); });
            }
        }
        addItemsBtn.addEventListener('click', () => { 
            if (itemScannerContainer.classList.contains('hidden')) startItemScanning(); 
            else stopItemScanning();
        });

        // Manual barcode entry
        document.getElementById('manualAddBtn').addEventListener('click', () => {
            const barcode = document.getElementById('manualBarcode').value.trim();
            if (!barcode) return alert('Enter a barcode');
            addItemByBarcode(barcode, (itemName) => {
                if (itemName) {
                    showSuccessToast(itemName, () => { document.getElementById('manualBarcode').value = ''; }, () => {
                        sessionStorage.setItem('checkoutCart', JSON.stringify(cart));
                        sessionStorage.setItem('checkoutMerchantId', currentMerchantId);
                        window.location.href = '/customer/cart';
                    });
                } else {
                    document.getElementById('manualBarcode').value = '';
                }
            });
        });

        document.getElementById('viewCartBtn').addEventListener('click', () => { 
            sessionStorage.setItem('checkoutCart', JSON.stringify(cart)); 
            sessionStorage.setItem('checkoutMerchantId', currentMerchantId); 
            window.location.href = '/customer/cart'; 
        });

        // Recent transactions – clickable
        fetch('/customer/api/recent-transactions').then(res=>res.json()).then(txns=>{ 
            const container=document.getElementById('recentTxns'); 
            if(txns.length===0) container.innerHTML='<div class="text-gray-500">No transactions yet</div>'; 
            else container.innerHTML=txns.map(t=>`
                <div class="bg-gray-800 p-2 rounded flex justify-between items-center cursor-pointer hover:bg-gray-700" onclick="window.location.href='/customer/receipt/${t.id}'">
                    <span>${t.store_name}</span>
                    <span>R${(t.total_cents/100).toFixed(2)}</span>
                    <span class="text-xs text-gray-400">${new Date(t.created_at*1000).toLocaleString()}</span>
                </div>
            `).join(''); 
        });
    </script>
</body>
</html>